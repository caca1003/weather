<WeatherScreen>:
    
    MDBoxLayout:
        orientation:"vertical"
        spacing:"20dp"
        MDTopAppBar:
            title: "Weather App"
        MDBoxLayout:
            spacing:"10dp"
            size_hint: 0.9, None
            pos_hint: {'center_x': 0.5}
            MDTextField:
                id: search_field
                hint_text: "Введіть місто"
                mode: "round"
            MDIconButton:
                icon: "magnify"
                id: search_button
                md_bg_color: app.theme_cls.primary_color
                on_press:root.search()
        MDBoxLayout:
            id: weather_info
            orientation:"vertical"
            spacing:"5dp"
            pos_hint: {'center_x': 0.5}
            size_hint:0.9, 0.9
            Widget:
                size_hint_y: None
                height: "50dp"
            MDLabel:
                id: temp_label
                text: ""
                font_style: "H3"
                halign: "center"
            MDLabel:
                id: text_label
                text: ""
                font_style: "Body1"
                halign: "center"
            AsyncImage:
                id: icon 
                source:""
                size_hint:None, None
                size:("150dp","150dp")
                fit_mode:"contain"
                pos_hint: {'center_x': 0.5}
            MDLabel:
                id: rain_label
                text: ""
                font_style: "Caption"
                halign: "center"
            MDLabel:
                id: wind_label
                text: ""
                font_style: "Caption"
                halign: "center"
            MDLabel:
                id: humidity_label
                text: ""
                font_style: "Caption"
                halign: "center"
            Widget:
                size_hint_y: None
                height: "50dp"